# TODO 1: Design Battery class with these methods:
#   - __init__(self, capacity): Initialize with starting capacity
#   - consume(self, amount): Reduce battery
#   - get_capacity(self): Return current battery
#   - get_status(self): Return string "Battery: X%"

class Battery:
    def __init__(self, capacity):
        self.capacity = capacity  # starting battery percentage 

    def consume(self, amount):
        """Reduce battery capacity by given percentage."""
        self.capacity = max(0, self.capacity - amount)

    def get_capacity(self):
        """Return the current battery percentage."""
        return self.capacity

    def get_status(self):
        """Return a formatted battery status string."""
        return f"Battery: {self.capacity}%"

# TODO 2: Design PathTracker class with these methods:
#   - __init__(self): Initialize tracker
#   - record_position(self, position): Save a position tuple
#   - get_step_count(self): Return number of positions 
#   - get_path(self): Return all positions

class PathTracker:
    def __init__(self):
        self.positions = []

    def record_position(self, position):
        """Store a position as a tuple (x, y)."""
        self.positions.append(position)

    def get_step_count(self):
        """Return the number of recorded steps."""
        return len(self.positions)

    def get_path(self):
        """Return all recorded positions."""
        return self.positions

# ========== END STUDENT SECTION ==========


def my_robot_program():
    program = create_robot_program(5, 5, 0, 0, mode="simulator")
    
    program.add_wall(1, 1)
    program.add_wall(2, 1)
    program.add_wall(1, 3)
    program.add_wall(0, 2)
    program.add_wall(1, 2)
    program.add_wall(3, 2)
    program.set_goal(2, 2)
    
    # TODO 3: Create your classes
    battery = Battery(100)
    tracker = PathTracker()
    
    # TODO 4: Connect them to program
    
    def moves():
        start = program.robot.position
        goal = program.goal
        walls = set(program.walls)
        
        grid_width = program.robot.grid_width
        grid_height = program.robot.grid_height
        
        queue = deque([(start, [])])
        visited = {start}
        
        while queue:
            (x, y), path = queue.popleft()

            if (x, y) == goal:
                for direction in path:
                    # TODO 5: Use your Battery to consume 5%
                    battery.consume(5)
                    
                    program.robot.move(direction)
                    
                    # TODO 6: Use your PathTracker to record position
                    tracker.record_position(program.robot.position)
                
                # TODO 7: Print results using your class 
                print(battery.get_status())
                print(f"Steps taken: {tracker.get_step_count()}")
                print(f"Path: {tracker.get_path()}")
                
                return
            
            for direction, (dx, dy) in [("right", (1,0)), ("up", (0,1)), 
                                       ("left", (-1,0)), ("down", (0,-1))]:
                nx, ny = x + dx, y + dy
                
                if (0 <= nx < grid_width and 0 <= ny < grid_height and 
                    (nx, ny) not in visited and (nx, ny) not in walls):
                    visited.add((nx, ny))
                    queue.append(((nx, ny), path + [direction]))
    
    run_with_visualization(program, moves)

if __name__ == "__main__":
    my_robot_program()
